  "info": {
    "_postman_id": "8898303e-f857-487d-a7b6-19a172bba9c9",
    "name": "Veracode Findings REST API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Veracode Findings REST API retrieves security findings from static analysis (SAST), dynamic analysis (DAST), manual penetration testing (MPT), and software composition analysis (SCA) scans. Supports filtering by CWE, severity, scan type, CVSS score, policy violations, and annotation status. Authentication uses HMAC with API ID/key credentials.\n\nContact Support:\n Name: Veracode Support",
      "type": "text/plain"
    }
  }

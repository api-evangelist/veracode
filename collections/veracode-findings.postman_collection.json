              "content": "Retrieves security findings for an application. Supports filtering by CWE, severity, scan type, CVSS score, policy violations, and annotation status.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "appsec",
                "v2",
                "applications",
                ":applicationGuid",
                "findings"
              ],
